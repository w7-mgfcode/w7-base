#!/usr/bin/env bash
# W7-Base CLI Entrypoint

set -e

if [[ -z "$W7_ROOT" ]]; then
  W7_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)
fi
W7_GLOBAL_ENV="${W7_ROOT}/.shared/global.env"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
NC='\033[0m'

usage() {
  echo -e "${GREEN}w7 - Local Orchestration Framework${NC}"
  echo "Usage: w7 [flags] <command> [stack-name]"
  echo ""
  echo "Flags:"
  echo "  --yes, -y       Skip interactive prompts (e.g., for @prod)"
  echo "  --force, -f     Force execution (bypasses some safety checks)"
  echo "  --json          Machine-readable output"
  echo "  --services      Show detailed service breakdown (for 'top')"
  echo "  --wide          Alias for --services with extra columns"
  echo "  --cold          (verify) Bring stack up before running checks"
  echo "  --running       (verify) Assume stack is up (default)"
  echo "  --seed-from-memory (verify) Seed fixtures from \${CLAUDE_PROJECT_DIR}/memory/"
  echo "  --keep          (verify) Skip cleanup of temp branch / Qdrant points"
  echo "  --apply         (seed) Push staged artifacts to Gitea (default: stage only)"
  echo "  --dry-run       (seed) Print plan, write nothing"
  echo ""
  echo "Commands:"
  echo "  up <stack|all>  Start a stack (wraps docker compose up -d)"
  echo "  down <stack|all> Stop a stack (wraps docker compose down)"
  echo "  top             Runtime resource visibility (grouped by zone/stack)"
  echo "  stats           Alias for 'top'"
  echo "  ps --res        Alias for 'top'"
  echo "  init <@zone/stack> Scaffold a new stack directory"
  echo "  doctor          Validate W7-Base environment and stack contract"
  echo "  secret <cmd> <stack> Manage encrypted secrets (edit, decrypt)"
  echo "  go <stack>      Navigate to stack dir (Requires shell integration)"
  echo "  stat            Show health matrix for all zones"
  echo "  backup <stack>  Archive stack data/ directory"
  echo "  logs <stack>    Tail zone-aware logs"
  echo "  net             Network port mapping visibility"
  echo "  prune           Cleanup unused Docker resources (with guardrails)"
  echo "  verify <stack>  Run stack-local end-to-end smoke (calls <stack>/scripts/verify.sh)"
  echo "  seed <stack>    Stage / push monorepo docs into stack KB (calls <stack>/scripts/seed-monorepo.sh)"
  echo "  resolve <stack> Internal: print resolved stack path"
}

log_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1" >&2; }

# Global flags
W7_YES=0
W7_FORCE=0
W7_JSON=0
W7_SERVICES=0
W7_WIDE=0
W7_VERIFY_COLD_FLAG=0
W7_VERIFY_RUNNING_FLAG=0
W7_VERIFY_SEED_FLAG=0
W7_VERIFY_KEEP_FLAG=0
W7_SEED_APPLY_FLAG=0
W7_SEED_DRY_RUN_FLAG=0

# Simple flag parser
POSITIONAL_ARGS=()
while [[ $# -gt 0 ]]; do
  case $1 in
    --yes|-y)
      W7_YES=1
      shift
      ;;
    --force|-f)
      W7_FORCE=1
      shift
      ;;
    --json)
      W7_JSON=1
      shift
      ;;
    --services)
      W7_SERVICES=1
      shift
      ;;
    --wide)
      W7_SERVICES=1
      W7_WIDE=1
      shift
      ;;
    --cold)
      W7_VERIFY_COLD_FLAG=1
      shift
      ;;
    --running)
      W7_VERIFY_RUNNING_FLAG=1
      shift
      ;;
    --seed-from-memory)
      W7_VERIFY_SEED_FLAG=1
      shift
      ;;
    --keep)
      W7_VERIFY_KEEP_FLAG=1
      shift
      ;;
    --apply)
      W7_SEED_APPLY_FLAG=1
      shift
      ;;
    --dry-run)
      W7_SEED_DRY_RUN_FLAG=1
      shift
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

# Mutually exclusive seed modes
if [[ "$W7_SEED_APPLY_FLAG" == "1" && "$W7_SEED_DRY_RUN_FLAG" == "1" ]]; then
  echo -e "\033[0;31m[ERROR]\033[0m --apply and --dry-run are mutually exclusive" >&2
  exit 1
fi

# Mutually exclusive verify modes
if [[ "$W7_VERIFY_COLD_FLAG" == "1" && "$W7_VERIFY_RUNNING_FLAG" == "1" ]]; then
  echo -e "\033[0;31m[ERROR]\033[0m --cold and --running are mutually exclusive" >&2
  exit 1
fi

set -- "${POSITIONAL_ARGS[@]}" # restore positional parameters

W7_CMD=$1
TARGET=$2

# Stack Resolution Algorithm
resolve_stack() {
  local target="$1"
  if [[ -z "$target" ]]; then
    log_error "Stack name required."
  fi

  # If user provided explicit zone (e.g. @dev/my-stack)
  if [[ "$target" == @*/* ]]; then
    local path="${W7_ROOT}/${target}"
    if [[ -d "$path" && -f "${path}/.w7-meta" ]]; then
      echo "$path"
      return 0
    fi
  fi

  # Search across all zones
  local matches=($(find "${W7_ROOT}" -maxdepth 3 -mindepth 3 -type f -name ".w7-meta" | awk -F'/' '{print $(NF-2)"/"$(NF-1)}' | grep "/${target}$" || true))
  
  if [[ ${#matches[@]} -eq 0 ]]; then
    log_error "Stack '${target}' not found in any zone."
  elif [[ ${#matches[@]} -gt 1 ]]; then
    log_error "Duplicate stacks found for '${target}'. Disambiguate by prepending the zone:"
    for m in "${matches[@]}"; do
      echo "  w7 <cmd> ${m}" >&2
    done
  else
    echo "${W7_ROOT}/${matches[0]}"
    return 0
  fi
}

setup_env() {
  local stack_path="$1"
  local rel_path="${stack_path#${W7_ROOT}/}"
  local zone=$(echo "$rel_path" | cut -d'/' -f1)
  local stack=$(echo "$rel_path" | cut -d'/' -f2)
  local zone_clean="${zone#@}"

  # W7-Base Contract: Daemon Isolation
  local project_name="${zone_clean}-${stack}"
  export COMPOSE_PROJECT_NAME=$(echo "$project_name" | tr '[:upper:]' '[:lower:]')

  # W7-Base Contract: Protected @prod
  if [[ "$zone" == "@prod" && "$W7_CMD" == "up" ]]; then
    # 1. Lock Check (W7-13.3)
    if [[ -f "${stack_path}/.w7-lock" ]]; then
      log_error "Stack is locked by .w7-lock. Deployment aborted."
      exit 1
    fi

    # 2. Confirmation Prompt (W7-13.1) & Bypass (W7-13.2)
    if [[ "$W7_YES" != "1" && "$W7_FORCE" != "1" ]]; then
      echo -ne "${YELLOW}ARE YOU SURE you want to deploy to @prod/${stack}? [y/N] ${NC}"
      read -r confirm
      if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        echo "Deployment cancelled."
        exit 0
      fi
    fi
  fi

  # Check Contract files
  if [[ ! -f "${stack_path}/compose.yml" ]]; then
    log_error "Missing compose.yml in ${stack_path}"
  fi

  # Secret Management Foundation (SOPS integration)
  if [[ -f "${stack_path}/.env.sops" ]]; then
    if [[ ! -f "${stack_path}/.env" ]] || [[ "${stack_path}/.env.sops" -nt "${stack_path}/.env" ]]; then
      if command -v sops &> /dev/null; then
        echo -e "${YELLOW}Auto-decrypting .env.sops to .env...${NC}"
        if ! sops -d --input-type dotenv --output-type dotenv "${stack_path}/.env.sops" > "${stack_path}/.env"; then
          log_error "Failed to decrypt ${stack_path}/.env.sops. Check your AGE key or SOPS config."
          exit 1
        fi
      else
        log_warn "Found .env.sops but 'sops' is not installed. Using existing .env if present."
      fi
    fi
  fi

  # Missing .env handling
  if [[ ! -f "${stack_path}/.env" && -f "${stack_path}/.env.example" && ! -f "${stack_path}/.env.sops" ]]; then
    if [[ "$W7_CMD" == "backup" || "$W7_CMD" == "logs" || "$W7_CMD" == "stat" ]]; then
      log_warn "Missing .env but .env.example exists. Proceeding for '$W7_CMD'."
    else
      log_error "Missing .env but .env.example exists. Please configure secrets."
      exit 1
    fi
  fi

  cd "$stack_path"
}

run_compose() {
  # Build compose args: merge global env and local env
  local compose_args=()
  if [[ -f "$W7_GLOBAL_ENV" ]]; then
    compose_args+=("--env-file" "$W7_GLOBAL_ENV")
  fi
  if [[ -f ".env" ]]; then
    compose_args+=("--env-file" ".env")
  fi

  # Run compose
  docker compose "${compose_args[@]}" "$@"
}

# --- Runtime Resource Visibility Implementation ---

render_top_table() {
  local gpu_total_load="-"
  if command -v nvidia-smi &>/dev/null; then
    gpu_total_load=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits || echo "-")
  fi

  local containers=$(docker ps --all --format "{{.ID}}|{{.Names}}|{{.Label \"com.docker.compose.project\"}}|{{.Label \"com.docker.compose.service\"}}|{{.Status}}|{{.Label \"w7.visibility.hide\"}}|{{.Label \"w7.platform.managed\"}}")
  local stats=$(docker stats --no-stream --format "{{.ID}}|{{.CPUPerc}}|{{.MemUsage}}|{{.NetIO}}")

  to_mb() {
    local raw="$1"
    local val=$(echo "$raw" | sed 's/[^0-9.]//g')
    local unit=$(echo "$raw" | sed 's/[0-9.]//g' | tr '[:upper:]' '[:lower:]' | xargs)
    if [[ "$unit" == *"gib"* || "$unit" == "gb" ]]; then echo "$val * 1024" | bc;
    elif [[ "$unit" == *"mib"* || "$unit" == "mb" || -z "$unit" ]]; then echo "$val" | bc;
    elif [[ "$unit" == *"kib"* || "$unit" == "kb" ]]; then echo "$val / 1024" | bc -l;
    elif [[ "$unit" == "b" ]]; then echo "$val / 1048576" | bc -l;
    else echo "0"; fi
  }

  get_zone() {
    local p="$1"
    if [[ "$p" == ops-* ]]; then echo "@ops";
    elif [[ "$p" == dev-* ]]; then echo "@dev";
    elif [[ "$p" == prod-* ]]; then echo "@prod";
    elif [[ "$p" == lab-* ]]; then echo "@lab";
    else echo "[ORPHAN]"; fi
  }

  declare -A zone_cpu zone_mem zone_gpu zone_count zone_svcs
  local g_cpu=0; local g_mem=0; local g_gpu=0; local g_count=0

  while IFS='|' read -r id name project service status hide managed; do
    if [[ "$hide" == "true" ]]; then continue; fi
    local zone=$(get_zone "$project")
    local stat_line=$(echo "$stats" | grep "^$id" || true)
    
    local cpu=0; local mem=0; local net="-"
    if [[ -n "$stat_line" ]]; then
      cpu=$(echo "$stat_line" | cut -d'|' -f2 | tr -d '%')
      local mem_raw=$(echo "$stat_line" | cut -d'|' -f3 | cut -d'/' -f1 | xargs)
      mem=$(to_mb "$mem_raw")
      net=$(echo "$stat_line" | cut -d'|' -f4)
    fi

    local gpu=0
    if [[ "$gpu_total_load" != "-" && "$status" == "Up"* ]]; then gpu="$gpu_total_load"; fi

    zone_cpu["$zone"]=$(echo "${zone_cpu["$zone"]:-0} + $cpu" | bc)
    zone_mem["$zone"]=$(echo "${zone_mem["$zone"]:-0} + $mem" | bc)
    zone_gpu["$zone"]=$(echo "${zone_gpu["$zone"]:-0} + $gpu" | bc)
    zone_count["$zone"]=$(( ${zone_count["$zone"]:-0} + 1 ))

    g_cpu=$(echo "$g_cpu + $cpu" | bc)
    g_mem=$(echo "$g_mem + $mem" | bc)
    g_gpu=$(echo "$g_gpu + $gpu" | bc)
    g_count=$((g_count + 1))

    if [[ "$W7_SERVICES" == "1" ]]; then
      local display_svc="${service:-$name}"
      if [[ "$managed" == "true" ]]; then display_svc="${GREEN}*${NC}${display_svc}"; fi
      local svc_line
      if [[ "$W7_WIDE" == "1" ]]; then
        svc_line=$(printf "  %-29b | %8.1f%% | %10.1f MiB | %5.1f%% | %-15s | %-20s" "$display_svc" "$cpu" "$mem" "$gpu" "$net" "$name")
      else
        svc_line=$(printf "  %-29b | %8.1f%% | %10.1f MiB | %5.1f%%" "$display_svc" "$cpu" "$mem" "$gpu")
      fi
      zone_svcs["$zone"]+="$svc_line"$'\n'
    fi
  done <<< "$containers"

  # Print Global Summary
  printf "${YELLOW}GLOBAL TOTAL: CPU:%-6.1f%%  MEM:%-10s  GPU:%-6.1f%%  Containers:%-3d${NC}\n\n" \
    "$g_cpu" "$(echo "$g_mem" | awk '{printf "%.1f MiB", $1}')" "$g_gpu" "$g_count"

  if [[ "$W7_SERVICES" == "1" ]]; then
    if [[ "$W7_WIDE" == "1" ]]; then
      printf "${GREEN}%-31s | %9s | %14s | %6s | %-15s | %-20s${NC}\n" "SERVICE" "CPU%" "MEM" "GPU%" "NET I/O" "CONTAINER"
      local sep="----------------------------------------------------------------------------------------------------------------------------"
    else
      printf "${GREEN}%-31s | %9s | %14s | %6s${NC}\n" "SERVICE" "CPU%" "MEM" "GPU%"
      local sep="--------------------------------------------------------------------------------"
    fi
    echo "$sep"
  else
    printf "${GREEN}%-10s | %10s | %14s | %8s | %5s${NC}\n" "ZONE" "CPU%" "MEM" "GPU%" "CNT"
    local sep="--------------------------------------------------------------------------------"
    echo "$sep"
  fi

  for z in @ops @dev @prod @lab "[ORPHAN]"; do
  if [[ ${zone_count["$z"]:-0} -eq 0 ]]; then continue; fi
  if [[ "$W7_SERVICES" == "1" ]]; then
    echo -e "${BLUE}$z${NC}"
    echo -ne "${zone_svcs["$z"]}"
    printf "${DIM}%-31s | %8.1f%% | %10.1f MiB | %5.1f%%${NC}\n" "  TOTAL" "${zone_cpu["$z"]}" "${zone_mem["$z"]}" "${zone_gpu["$z"]}"
    echo "$sep"
  else
    printf "%-10s | %9.1f%% | %10.1f MiB | %7.1f%% | %5d\n" "$z" "${zone_cpu["$z"]}" "${zone_mem["$z"]}" "${zone_gpu["$z"]}" "${zone_count["$z"]}"
  fi
  done
  }

  render_net_table() {
  local containers=$(docker ps --all --format "{{.ID}}|{{.Names}}|{{.Label \"com.docker.compose.project\"}}|{{.Label \"com.docker.compose.service\"}}|{{.Ports}}|{{.Label \"w7.visibility.hide\"}}")

  get_zone() {
  local p="$1"
  if [[ "$p" == ops-* ]]; then echo "@ops";
  elif [[ "$p" == dev-* ]]; then echo "@dev";
  elif [[ "$p" == prod-* ]]; then echo "@prod";
  elif [[ "$p" == lab-* ]]; then echo "@lab";
  else echo "[ORPHAN]"; fi
  }

  declare -A zone_net
  while IFS='|' read -r id name project service ports hide; do
  if [[ "$hide" == "true" ]]; then continue; fi
  local zone=$(get_zone "$project")
  local display_svc="${service:-$name}"

  # Process ports: "0.0.0.0:80->80/tcp, :::80->80/tcp" -> "80:80"
  # Or "80/tcp" (internal)
  local mapping=""
  if [[ -z "$ports" ]]; then
    mapping="${DIM}none${NC}"
  else
    # Split by comma
    IFS=',' read -ra ADDR <<< "$ports"
    for p in "${ADDR[@]}"; do
      p=$(echo "$p" | xargs)
      if [[ "$p" == *"->"* ]]; then
        local host_port=$(echo "$p" | cut -d'->' -f1 | rev | cut -d':' -f1 | rev)
        local cont_port=$(echo "$p" | cut -d'->' -f2 | cut -d'/' -f1)
        mapping+="${host_port}:${cont_port} "
      else
        local int_port=$(echo "$p" | cut -d'/' -f1)
        mapping+="${DIM}${int_port}(int)${NC} "
      fi
    done
  fi

  local line=$(printf "  %-25s | %-25s | %b" "$project" "$display_svc" "$mapping")
  zone_net["$zone"]+="$line"$'\n'
  done <<< "$containers"

  printf "${GREEN}%-27s | %-25s | %-20s${NC}\n" "STACK/PROJECT" "SERVICE" "PORTS (Host:Cont)"
  echo "--------------------------------------------------------------------------------"
  for z in @ops @dev @prod @lab "[ORPHAN]"; do
  if [[ -n "${zone_net["$z"]}" ]]; then
    echo -e "${BLUE}$z${NC}"
    echo -ne "${zone_net["$z"]}"
  fi
  done
  }

  render_top_json() {
  local gpu_total_load="-"
  if command -v nvidia-smi &>/dev/null; then
  gpu_total_load=$(nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits || echo "-")
  fi

  get_zone() {
  local p="$1"
  if [[ "$p" == ops-* ]]; then echo "@ops";
  elif [[ "$p" == dev-* ]]; then echo "@dev";
  elif [[ "$p" == prod-* ]]; then echo "@prod";
  elif [[ "$p" == lab-* ]]; then echo "@lab";
  else echo "[ORPHAN]"; fi
  }

  echo "["
  local containers=$(docker ps --all --format "{{.ID}}|{{.Names}}|{{.Label \"com.docker.compose.project\"}}|{{.Label \"com.docker.compose.service\"}}|{{.Status}}|{{.Label \"w7.visibility.hide\"}}|{{.Label \"w7.platform.managed\"}}|{{.Ports}}")
  local stats=$(docker stats --no-stream --format "{{.ID}}|{{.CPUPerc}}|{{.MemUsage}}|{{.NetIO}}")

  local first=1
  while IFS='|' read -r id name project service status hide managed ports; do
  if [[ $first -eq 0 ]]; then echo ","; fi
  first=0

  local zone=$(get_zone "$project")
  local stat_line=$(echo "$stats" | grep "^$id" || true)
  local cpu="0%"; local mem="0B"; local net="0B/0B"
  if [[ -n "$stat_line" ]]; then
    cpu=$(echo "$stat_line" | cut -d'|' -f2)
    mem=$(echo "$stat_line" | cut -d'|' -f3 | cut -d'/' -f1 | xargs)
    net=$(echo "$stat_line" | cut -d'|' -f4)
  fi

  local json_project="\"$project\""
  if [[ -z "$project" ]]; then json_project="null"; fi
  local json_hide="false"; if [[ "$hide" == "true" ]]; then json_hide="true"; fi
  local json_managed="false"; if [[ "$managed" == "true" ]]; then json_managed="true"; fi
  local json_ports=$(echo "$ports" | sed 's/"/\\"/g')

  echo "  {"
  echo "    \"id\": \"$id\","
  echo "    \"name\": \"$name\","
  echo "    \"project\": $json_project,"
  echo "    \"zone\": \"$zone\","
  echo "    \"status\": \"$status\","
  echo "    \"cpu_perc\": \"$cpu\","
  echo "    \"mem_usage\": \"$mem\","
  echo "    \"net_io\": \"$net\","
  echo "    \"port_mapping\": \"$json_ports\","
  echo "    \"hide\": $json_hide,"
  echo "    \"managed\": $json_managed,"
  echo "    \"gpu_perc\": \"${gpu_total_load}%\""
  echo "  }"
  done <<< "$containers"
  echo "]"
  }
case "$W7_CMD" in
  top|stats)
    if [[ "$W7_JSON" == "1" ]]; then
      render_top_json
    else
      echo -e "${GREEN}W7 Runtime Resource Visibility${NC}"
      render_top_table
    fi
    ;;
  net)
    if [[ "$W7_JSON" == "1" ]]; then
      render_top_json
    else
      echo -e "${GREEN}W7 Network Port Visibility${NC}"
      render_net_table
    fi
    ;;
  ps)
    if [[ "$TARGET" == "--res" ]]; then
      if [[ "$W7_JSON" == "1" ]]; then render_top_json; else echo -e "${GREEN}W7 Runtime Resource Visibility${NC}"; render_top_table; fi
    else
      log_error "Usage: w7 ps --res"
    fi
    ;;
  secret)
    SUBCMD=$2
    TARGET=$3
    if [[ -z "$SUBCMD" || -z "$TARGET" ]]; then
      echo "Usage: w7 secret <edit|decrypt|init> <stack>"
      exit 1
    fi
    SPATH=$(resolve_stack "$TARGET")
    
    if ! command -v sops &> /dev/null; then
      log_error "'sops' is not installed. Please install Mozilla SOPS."
      exit 1
    fi
    
    case "$SUBCMD" in
      init)
        if [[ -f "${SPATH}/.env.sops" ]]; then
           log_error "${SPATH}/.env.sops already exists."
           exit 1
        fi
        echo -e "${GREEN}Creating new .env.sops for stack...${NC}"
        cd "$SPATH"
        if [[ -f ".env" ]]; then
           sops -e --input-type dotenv --output-type dotenv ".env" > ".env.sops"
           echo -e "${GREEN}Encrypted existing .env into .env.sops${NC}"
        else
           touch .env.empty
           sops -e --input-type dotenv --output-type dotenv .env.empty > ".env.sops"
           rm .env.empty
           echo -e "${GREEN}Created empty .env.sops${NC}"
        fi
        ;;
      edit)
        echo -e "${GREEN}Opening .env.sops in SOPS editor...${NC}"
        cd "$SPATH"
        sops --input-type dotenv --output-type dotenv "${SPATH}/.env.sops"
        ;;
      decrypt)
        echo -e "${GREEN}Decrypting .env.sops to .env...${NC}"
        cd "$SPATH"
        sops -d --input-type dotenv --output-type dotenv "${SPATH}/.env.sops" > "${SPATH}/.env"
        ;;
      *)
        echo "Unknown secret command: $SUBCMD"
        exit 1
        ;;
    esac
    ;;
  init)
    if [[ -z "$TARGET" ]]; then
      log_error "Stack name required (e.g., w7 init @dev/my-stack)."
      exit 1
    fi
    if [[ "$TARGET" != @*/* ]]; then
      log_error "Must specify zone prefix (e.g., @dev/my-stack, @lab/test-stack)."
      exit 1
    fi
    zone=$(echo "$TARGET" | cut -d'/' -f1)
    stack=$(echo "$TARGET" | cut -d'/' -f2)
    stack_path="${W7_ROOT}/${zone}/${stack}"
    
    if [[ ! -d "${W7_ROOT}/${zone}" ]]; then
      log_error "Zone '${zone}' does not exist."
      exit 1
    fi
    
    if [[ -d "$stack_path" ]]; then
      log_error "Stack directory '${stack_path}' already exists."
      exit 1
    fi
    
    echo -e "${GREEN}Scaffolding new stack: ${TARGET}${NC}"
    mkdir -p "${stack_path}/data"
    
    cat << EOF > "${stack_path}/.w7-meta"
version: "1.0"
description: "Autogenerated stack for ${stack}"
git_trigger:
  repository: "gitea_user/repo_name"
  branch: "main"
health_checks:
  - type: "http"
    endpoint: "http://localhost:8080/health"
EOF

    cat << EOF > "${stack_path}/compose.yml"
services:
  app:
    image: alpine:latest
    container_name: \${COMPOSE_PROJECT_NAME}-app
    command: tail -f /dev/null
    volumes:
      - ./data:/data
    restart: unless-stopped
EOF

    cat << EOF > "${stack_path}/.env.example"
# Required environment variables for ${stack}
# Define each required key with an example (non-secret) value.
# Operators copy this to .env and fill in real values.
# APP_PORT=8080
# DB_PASSWORD=changeme
EOF

    cat << EOF > "${stack_path}/.env"
# Stack: ${TARGET}
# Copy values from .env.example and set real secrets here.
# This file is excluded from Git by .gitignore.
EOF

    echo -e "${GREEN}Success! Stack created at ${TARGET}${NC}"
    echo -e "Next steps:"
    echo -e "  1. Edit ${zone}/${stack}/.env.example with required variable names"
    echo -e "  2. Copy to .env and fill in real secrets"
    echo -e "  3. w7 up ${TARGET}"
    if [[ "$zone" == "@prod" || "$zone" == "@ops" ]]; then
      echo -e "  ${YELLOW}Tip:${NC} For ${zone}, consider encrypting secrets with: w7 secret init ${TARGET}"
    fi
    ;;
  up)
    if [[ "$TARGET" == "all" ]]; then
      # Start @ops first, then others
      echo -e "${YELLOW}Starting ALL stacks...${NC}"
      ops_stacks=($(find "${W7_ROOT}/@ops" -maxdepth 2 -mindepth 2 -type f -name ".w7-meta" | awk -F'/' '{print "@ops/"$(NF-1)}'))
      other_stacks=($(find "${W7_ROOT}" -maxdepth 3 -mindepth 3 -type f -name ".w7-meta" | grep -v "/@ops/" | awk -F'/' '{print $(NF-2)"/"$(NF-1)}'))

      for s in "${ops_stacks[@]}" "${other_stacks[@]}"; do
        echo -e "\n${BLUE}>>> Up: $s${NC}"
        (
          # Check if we need to pass --yes to ourselves for @prod
          extra_args=""
          if [[ "$W7_YES" == "1" ]]; then extra_args="--yes"; fi
          if [[ "$W7_FORCE" == "1" ]]; then extra_args="${extra_args} --force"; fi
          
          # Resolve and setup
          spath=$(resolve_stack "$s")
          setup_env "$spath"
          docker network inspect w7-ingress >/dev/null 2>&1 || docker network create w7-ingress
          run_compose up -d
        )
      done
    else
      SPATH=$(resolve_stack "$TARGET")
      setup_env "$SPATH"
      echo -e "${GREEN}Booting stack: ${COMPOSE_PROJECT_NAME}${NC}"
      docker network inspect w7-ingress >/dev/null 2>&1 || docker network create w7-ingress
      run_compose up -d
    fi
    ;;
  down)
    if [[ "$TARGET" == "all" ]]; then
      # Stop others first, then @ops last
      echo -e "${YELLOW}Stopping ALL stacks...${NC}"
      ops_stacks=($(find "${W7_ROOT}/@ops" -maxdepth 2 -mindepth 2 -type f -name ".w7-meta" | awk -F'/' '{print "@ops/"$(NF-1)}'))
      other_stacks=($(find "${W7_ROOT}" -maxdepth 3 -mindepth 3 -type f -name ".w7-meta" | grep -v "/@ops/" | awk -F'/' '{print $(NF-2)"/"$(NF-1)}'))
      
      for s in "${other_stacks[@]}" "${ops_stacks[@]}"; do
        echo -e "\n${BLUE}>>> Down: $s${NC}"
        (
          spath=$(resolve_stack "$s")
          setup_env "$spath"
          run_compose down
        )
      done
    else
      SPATH=$(resolve_stack "$TARGET")
      setup_env "$SPATH"
      echo -e "${GREEN}Stopping stack: ${COMPOSE_PROJECT_NAME}${NC}"
      run_compose down
    fi
    ;;
  logs)
    SPATH=$(resolve_stack "$TARGET")
    setup_env "$SPATH"
    # Zone-aware prefix logging
    run_compose logs -f --tail=100
    ;;
  resolve)
    # Internal command used by 'w7 go' shell wrapper
    resolve_stack "$TARGET"
    ;;
  go)
    log_error "\'w7 go\' must be run via the shell wrapper. Ensure you have sourced .shared/w7.sh in your .bashrc/.zshrc"
    exit 1
    ;;
  stat)
    echo -e "${GREEN}W7-Base Health Matrix${NC}"
    printf "%-10s | %-20s | %-15s | %-20s\n" "ZONE" "STACK" "STATUS" "IMAGE"
    echo "-----------------------------------------------------------------------"
    
    # Iterate over all zones to build the matrix
    for z in @ops @dev @prod @lab; do
      zone_clean="${z#@}"
      if [ -d "$W7_ROOT/$z" ]; then
        for stack_path in "$W7_ROOT/$z"/*; do
          if [ -f "$stack_path/.w7-meta" ]; then
            stack=$(basename "$stack_path")
            proj_name="${zone_clean}-${stack}"
            proj_name_lower=$(echo "$proj_name" | tr '[:upper:]' '[:lower:]')
            
            # Get running container count for the project
            running=$(docker ps --filter "label=com.docker.compose.project=$proj_name_lower" --format "{{.Names}}" | wc -l)
            
            status_txt="Down"
            color_open=""
            color_close=""
            if [ "$running" -gt 0 ]; then
               status_txt="Up ($running)"
               color_open="$GREEN"
               color_close="$NC"
            fi

            # %b interprets the \033 escapes in $color_open/$color_close; %-15s
            # pads visible content to the same width as the STATUS header above.
            printf "%-10s | %-20s | %b%-15s%b | %-20s\n" "$z" "$stack" "$color_open" "$status_txt" "$color_close" "-"
          fi
        done
      fi
    done
    
    echo ""
    echo -e "${YELLOW}Note: For deeper insights, use 'docker stats' or a visualizer like Dozzle.${NC}"
    ;;
  backup)
    SPATH=$(resolve_stack "$TARGET")
    setup_env "$SPATH"
    
    if [ ! -d "data" ]; then
      log_error "No 'data/' directory found in stack. Nothing to backup."
      exit 1
    fi
    
    # Pre-check for read and traverse permissions
    if find data/ \( -not -readable -o \( -type d -not -executable \) \) -print -quit 2>/dev/null | grep -q .; then
      log_error "Permission denied: unable to read or traverse some files in 'data/'."
      echo -e "${YELLOW}Hint: The container likely created files as root or another UID.${NC}"
      echo -e "${YELLOW}Run this backup command with 'sudo' to safely read and archive the volume.${NC}"
      exit 1
    fi
    
    archive_name="${COMPOSE_PROJECT_NAME}_backup_$(date +%Y%m%d_%H%M%S).tar.gz"
    echo -e "${GREEN}Creating backup of data/ to ${archive_name}...${NC}"
    # Explicitly exclude .env and other non-data files
    if ! tar -czf "$archive_name" data/; then
       log_error "Backup failed during tar execution."
       exit 1
    fi
    echo -e "${GREEN}Backup complete: $SPATH/$archive_name${NC}"
    ;;
  prune)
    SPATH=$(resolve_stack "$TARGET")
    setup_env "$SPATH"
    
    rel_path="${SPATH#${W7_ROOT}/}"
    zone=$(echo "$rel_path" | cut -d'/' -f1)
    
    if [[ "$zone" != "@lab" ]]; then
      log_error "'prune' is strictly limited to the @lab zone to prevent accidental data loss in persistent zones."
      exit 1
    fi
    
    echo -e "${YELLOW}Pruning stack ${COMPOSE_PROJECT_NAME} in @lab...${NC}"
    run_compose down -v --remove-orphans
    ;;
  verify)
    if [[ -z "$TARGET" ]]; then
      log_error "Stack name required. Usage: w7 verify <stack> [--cold|--running] [--seed-from-memory] [--keep]"
      exit 1
    fi
    SPATH=$(resolve_stack "$TARGET")
    if [[ ! -x "${SPATH}/scripts/verify.sh" ]]; then
      log_error "Stack '${TARGET}' has no executable scripts/verify.sh — feature not supported by this stack."
      exit 2
    fi

    # Decrypt secrets if needed (verify.sh reads .env for GITEA_TOKEN etc.)
    setup_env "$SPATH"

    # Export contract envvars for the stack-local script
    if [[ "$W7_VERIFY_COLD_FLAG" == "1" ]]; then
      export W7_VERIFY_COLD=1
      export W7_VERIFY_RUNNING=0
    else
      export W7_VERIFY_COLD=0
      export W7_VERIFY_RUNNING=1
    fi
    export W7_VERIFY_SEED_FROM_MEMORY="$W7_VERIFY_SEED_FLAG"
    export W7_VERIFY_KEEP="$W7_VERIFY_KEEP_FLAG"
    export W7_VERIFY_OUTPUT_DIR="${SPATH}/dogfood-output/$(date -u +%Y%m%dT%H%M%SZ)"
    mkdir -p "$W7_VERIFY_OUTPUT_DIR"

    set +e
    bash "${SPATH}/scripts/verify.sh"
    EXIT=$?
    set -e

    if [[ "$W7_JSON" == "1" && -f "${W7_VERIFY_OUTPUT_DIR}/result.json" ]]; then
      cat "${W7_VERIFY_OUTPUT_DIR}/result.json"
    fi
    exit $EXIT
    ;;
  seed)
    if [[ -z "$TARGET" ]]; then
      log_error "Stack name required. Usage: w7 seed <stack> [--apply|--dry-run]"
      exit 1
    fi
    SPATH=$(resolve_stack "$TARGET")
    if [[ ! -x "${SPATH}/scripts/seed-monorepo.sh" ]]; then
      log_error "Stack '${TARGET}' has no executable scripts/seed-monorepo.sh — feature not supported by this stack."
      exit 2
    fi

    # Decrypt secrets if needed (--apply reads .env for GITEA_TOKEN etc.)
    setup_env "$SPATH"

    set +e
    if [[ "$W7_SEED_APPLY_FLAG" == "1" ]]; then
      bash "${SPATH}/scripts/seed-monorepo.sh" --apply
    elif [[ "$W7_SEED_DRY_RUN_FLAG" == "1" ]]; then
      bash "${SPATH}/scripts/seed-monorepo.sh" --dry-run
    else
      bash "${SPATH}/scripts/seed-monorepo.sh"
    fi
    EXIT=$?
    set -e
    exit $EXIT
    ;;
  doctor)
    if [[ "$W7_JSON" == "1" ]]; then
      # JSON reporting mode
      JSON_FILE=$(mktemp)
      echo '{"status": "unknown", "errors": [], "warnings": []}' > "$JSON_FILE"
      
      add_json() {
        local type="$1"
        local msg="$2"
        # Poor man's JSON append via python or sed (using python if available)
        if command -v python3 &>/dev/null; then
          python3 -c "import json, sys; d=json.load(open('$JSON_FILE')); d['$type'].append(sys.argv[1]); json.dump(d, open('$JSON_FILE', 'w'))" "$msg"
        fi
      }
    else
      echo -e "${GREEN}W7-Base System Validation (Doctor)${NC}"
      echo "================================================="
    fi
    
    errors=0
    warnings=0
    
    check_tool() {
      if ! command -v "$1" &> /dev/null; then
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "errors" "Missing tool: $1"
        else
          echo -e "${RED}[ERROR]${NC} Missing required tool: $1"
        fi
        errors=$((errors+1))
      else
        if [[ "$W7_JSON" != "1" ]]; then
          echo -e "${GREEN}[OK]${NC} Tool '$1' is installed."
        fi
      fi
    }
    
    check_optional_tool() {
      if ! command -v "$1" &> /dev/null; then
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "warnings" "Optional tool missing: $1"
        else
          echo -e "${YELLOW}[WARN]${NC} Optional tool missing: $1 (Required for secret management)"
        fi
        warnings=$((warnings+1))
      else
        if [[ "$W7_JSON" != "1" ]]; then
          echo -e "${GREEN}[OK]${NC} Optional tool '$1' is installed."
        fi
      fi
    }
    
    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}1. Core Dependencies${NC}"; fi
    check_tool "docker"
    check_tool "tar"
    check_tool "bash"
    if docker compose version &> /dev/null; then
      if [[ "$W7_JSON" != "1" ]]; then echo -e "${GREEN}[OK]${NC} Tool 'docker compose' plugin is installed."; fi
    else
      if [[ "$W7_JSON" == "1" ]]; then
        add_json "errors" "Missing tool: docker compose plugin"
      else
        echo -e "${RED}[ERROR]${NC} Missing required tool: docker compose plugin"
      fi
      errors=$((errors+1))
    fi
    check_optional_tool "sops"
    check_optional_tool "age"
    
    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}2. Directory Structure & Zones${NC}"; fi
    for z in @ops @dev @prod @lab .shared .bin; do
      if [[ -d "${W7_ROOT}/$z" ]]; then
        if [[ "$W7_JSON" != "1" ]]; then echo -e "${GREEN}[OK]${NC} Required directory '$z' exists."; fi
      else
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "errors" "Missing required directory: $z"
        else
          echo -e "${RED}[ERROR]${NC} Missing required directory: '$z'"
        fi
        errors=$((errors+1))
      fi
    done
    
    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}3. Environment Bridge & Shell Integrations${NC}"; fi
    if [[ -f "${W7_ROOT}/.shared/global.env" ]]; then
      if [[ "$W7_JSON" != "1" ]]; then echo -e "${GREEN}[OK]${NC} .shared/global.env exists."; fi
    else
      if [[ "$W7_JSON" == "1" ]]; then
        add_json "warnings" ".shared/global.env is missing"
      else
        echo -e "${YELLOW}[WARN]${NC} .shared/global.env is missing. Recommended for global variables."
      fi
      warnings=$((warnings+1))
    fi
    if [[ -f "${W7_ROOT}/.shared/w7.sh" ]]; then
      if [[ "$W7_JSON" != "1" ]]; then echo -e "${GREEN}[OK]${NC} .shared/w7.sh shell integration exists."; fi
    else
      if [[ "$W7_JSON" == "1" ]]; then
        add_json "errors" ".shared/w7.sh is missing"
      else
        echo -e "${RED}[ERROR]${NC} .shared/w7.sh is missing. 'w7 go' and aliases will fail."
      fi
      errors=$((errors+1))
    fi
    
    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}4. Secret Management${NC}"; fi
    if [[ -f "${W7_ROOT}/.gitignore" ]]; then
      if grep -q '\.env' "${W7_ROOT}/.gitignore"; then
        if [[ "$W7_JSON" != "1" ]]; then echo -e "${GREEN}[OK]${NC} .gitignore exists and excludes .env files."; fi
      else
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "warnings" ".gitignore does not exclude .env"
        else
          echo -e "${YELLOW}[WARN]${NC} .gitignore exists but does not exclude .env files."
        fi
        warnings=$((warnings+1))
      fi
    else
      if [[ "$W7_JSON" == "1" ]]; then
        add_json "errors" "No .gitignore found"
      else
        echo -e "${RED}[ERROR]${NC} No .gitignore found. Secrets may be committed accidentally."
      fi
      errors=$((errors+1))
    fi
    if [[ -f "${W7_ROOT}/.sops.yaml" ]]; then
      if [[ "$W7_JSON" != "1" ]]; then echo -e "${GREEN}[OK]${NC} .sops.yaml SOPS configuration exists."; fi
      if grep -q 'age1xx' "${W7_ROOT}/.sops.yaml"; then
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "warnings" ".sops.yaml contains placeholder AGE key"
        else
          echo -e "${YELLOW}[WARN]${NC} .sops.yaml contains placeholder AGE key. Run 'age-keygen' and update .sops.yaml."
        fi
        warnings=$((warnings+1))
      fi
    else
      if [[ "$W7_JSON" == "1" ]]; then
        add_json "warnings" ".sops.yaml not found"
      else
        echo -e "${YELLOW}[WARN]${NC} .sops.yaml not found. SOPS encryption is not configured."
      fi
      warnings=$((warnings+1))
    fi

    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}5. Stack Contract Validation${NC}"; fi
    declare -A stack_names
    for z in @ops @dev @prod @lab; do
      if [[ -d "${W7_ROOT}/$z" ]]; then
        for stack_path in "${W7_ROOT}/$z"/*; do
          if [[ -f "${stack_path}/.w7-meta" ]]; then
            stack=$(basename "$stack_path")
            if [[ "$W7_JSON" != "1" ]]; then echo "Checking stack: $z/$stack"; fi
            
            # Duplicate name check
            if [[ -n "${stack_names[$stack]}" ]]; then
              if [[ "$W7_JSON" == "1" ]]; then
                add_json "warnings" "Duplicate stack name: $stack in $z and ${stack_names[$stack]}"
              else
                echo -e "  ${YELLOW}[WARN]${NC} Duplicate stack name '$stack' found in both '$z' and '${stack_names[$stack]}'. w7 resolves explicitly via zone prefix."
              fi
              warnings=$((warnings+1))
            fi
            stack_names[$stack]="$z"
            
            # File checks
            if [[ ! -f "${stack_path}/compose.yml" ]]; then
              if [[ "$W7_JSON" == "1" ]]; then
                add_json "errors" "$z/$stack missing compose.yml"
              else
                echo -e "  ${RED}[ERROR]${NC} Missing compose.yml"
              fi
              errors=$((errors+1))
            fi
            if [[ ! -d "${stack_path}/data" ]]; then
              if [[ "$W7_JSON" == "1" ]]; then
                add_json "warnings" "$z/$stack missing data/ dir"
              else
                echo -e "  ${YELLOW}[WARN]${NC} Missing data/ directory. Persistent volumes might not be isolated."
              fi
              warnings=$((warnings+1))
            fi
            if [[ ! -f "${stack_path}/.env" && ! -f "${stack_path}/.env.example" && ! -f "${stack_path}/.env.sops" ]]; then
              if [[ "$W7_JSON" == "1" ]]; then
                add_json "warnings" "$z/$stack no env files"
              else
                echo -e "  ${YELLOW}[WARN]${NC} Neither .env, .env.example, nor .env.sops exists."
              fi
              warnings=$((warnings+1))
            fi
            
            if [[ -f "${stack_path}/.env.sops" && ! -f "${W7_ROOT}/.sops.yaml" && ! -f "${stack_path}/.sops.yaml" ]]; then
              if [[ "$W7_JSON" == "1" ]]; then
                add_json "warnings" "$z/$stack .env.sops found but no .sops.yaml"
              else
                echo -e "  ${YELLOW}[WARN]${NC} .env.sops found but no .sops.yaml in root or stack."
              fi
              warnings=$((warnings+1))
            fi

            # .env key validation against .env.example
            if [[ -f "${stack_path}/.env.example" && -f "${stack_path}/.env" ]]; then
              # Extract non-comment, non-empty KEY= lines from .env.example
              missing_keys=""
              while IFS= read -r line; do
                key=$(echo "$line" | grep -oP '^\s*[A-Za-z_][A-Za-z0-9_]*(?==)' || true)
                if [[ -n "$key" ]]; then
                  if ! grep -qP "^\s*${key}\s*=" "${stack_path}/.env" 2>/dev/null; then
                    missing_keys="${missing_keys} ${key}"
                  fi
                fi
              done < "${stack_path}/.env.example"
              if [[ -n "$missing_keys" ]]; then
                if [[ "$W7_JSON" == "1" ]]; then
                  add_json "warnings" "$z/$stack missing env keys: $missing_keys"
                else
                  echo -e "  ${YELLOW}[WARN]${NC} .env is missing keys defined in .env.example:${missing_keys}"
                fi
                warnings=$((warnings+1))
              fi
            fi

            # Compose config validation
            (
              cd "$stack_path"
              zone_clean="${z#@}"
              export COMPOSE_PROJECT_NAME="${zone_clean}-${stack}"
              compose_args=()
              if [[ -f "$W7_GLOBAL_ENV" ]]; then compose_args+=("--env-file" "$W7_GLOBAL_ENV"); fi
              if [[ -f ".env" ]]; then compose_args+=("--env-file" ".env"); fi
              docker compose "${compose_args[@]}" config -q &>/dev/null
            )
            if [[ $? -eq 0 ]]; then
               if [[ "$W7_JSON" != "1" ]]; then echo -e "  ${GREEN}[OK]${NC} compose config is valid."; fi
            else
               if [[ "$W7_JSON" == "1" ]]; then
                 add_json "errors" "$z/$stack docker compose validation failed"
               else
                 echo -e "  ${RED}[ERROR]${NC} docker compose config validation failed for $z/$stack"
               fi
               errors=$((errors+1))
            fi
          fi
        done
      fi
    done

    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}6. GitOps & Pipeline Diagnostics (v2)${NC}"; fi
    
    # 14.1 Webhook HMAC check
    if [[ -f "${W7_ROOT}/@ops/webhook/.env" ]]; then
      W_SECRET=$(grep '^WEBHOOK_SECRET=' "${W7_ROOT}/@ops/webhook/.env" | cut -d'=' -f2- || true)
      if [[ -z "$W_SECRET" || "$W_SECRET" == "CHANGE_ME_IN_PRODUCTION" ]]; then
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "warnings" "Webhook secret is missing or default"
        else
          echo -e "  ${YELLOW}[WARN]${NC} Webhook secret is missing or using default value in @ops/webhook/.env"
        fi
        warnings=$((warnings+1))
      else
        if [[ "$W7_JSON" != "1" ]]; then echo -e "  ${GREEN}[OK]${NC} Webhook secret is configured."; fi
      fi
    fi

    # 14.2 act-runner status
    if docker ps --filter "name=act-runner" --format "{{.Status}}" | grep -q "Up"; then
      if [[ "$W7_JSON" != "1" ]]; then echo -e "  ${GREEN}[OK]${NC} act-runner container is running."; fi
    else
      if [[ "$W7_JSON" == "1" ]]; then
        add_json "warnings" "act-runner is not running"
      else
        echo -e "  ${YELLOW}[WARN]${NC} act-runner container is not running."
      fi
      warnings=$((warnings+1))
    fi

    # 14.3 Traefik Ingress Connectivity (Localhost DNS check)
    for domain in git.w7.local logs.w7.local; do
      if grep -q "$domain" /etc/hosts 2>/dev/null; then
        if [[ "$W7_JSON" != "1" ]]; then echo -e "  ${GREEN}[OK]${NC} Ingress domain '$domain' found in /etc/hosts."; fi
      else
        if [[ "$W7_JSON" == "1" ]]; then
          add_json "warnings" "Ingress domain '$domain' missing in /etc/hosts"
        else
          echo -e "  ${YELLOW}[WARN]${NC} Ingress domain '$domain' not found in /etc/hosts. Local routing may fail."
        fi
        warnings=$((warnings+1))
      fi
    done

    # 14.4 Secret Sealing (@prod)
    for stack_path in "${W7_ROOT}/@prod"/*; do
      if [[ -d "$stack_path" && -f "${stack_path}/.w7-meta" ]]; then
        stack=$(basename "$stack_path")
        if [[ ! -f "${stack_path}/.env.sops" ]]; then
          if [[ "$W7_JSON" == "1" ]]; then
            add_json "warnings" "Prod stack @prod/$stack is not sealed"
          else
            echo -e "  ${YELLOW}[WARN]${NC} Prod stack '@prod/$stack' is not sealed (.env.sops missing)."
          fi
          warnings=$((warnings+1))
        fi
      fi
    done

    if [[ "$W7_JSON" != "1" ]]; then echo -e "\n${YELLOW}7. Policy Compliance${NC}"; fi
    for z in @ops @dev @prod @lab; do
      if [[ -d "${W7_ROOT}/$z" ]]; then
        for stack_path in "${W7_ROOT}/$z"/*; do
          if [[ -f "${stack_path}/.w7-meta" ]]; then
            stack=$(basename "$stack_path")
            
            # Run local-first policies from .shared/policy/*.sh
            for policy_script in "${W7_ROOT}/.shared/policy"/*.sh; do
              if [[ -f "$policy_script" ]]; then
                # Source and run the policy's 'check_policy' function
                # We use a subshell to isolate the policy script but we must 
                # be careful with 'set -e' in the main script.
                (
                  source "$policy_script"
                  if [[ "$W7_JSON" == "1" ]]; then
                    check_policy "$z" "$stack" "$stack_path" >/dev/null
                  else
                    check_policy "$z" "$stack" "$stack_path"
                  fi
                ) || {
                  if [[ "$W7_JSON" == "1" ]]; then
                    add_json "errors" "$z/$stack violated $(basename "$policy_script")"
                  else
                    echo -e "  ${RED}[POLICY FAIL]${NC} $z/$stack violated '$(basename "$policy_script")'"
                  fi
                  errors=$((errors+1))
                }
              fi
            done
          fi
        done
      fi
    done
    
    if [[ "$W7_JSON" == "1" ]]; then
      status="healthy"
      if [[ $errors -gt 0 ]]; then status="error"; elif [[ $warnings -gt 0 ]]; then status="warning"; fi
      python3 -c "import json; d=json.load(open('$JSON_FILE')); d['status']='$status'; d['error_count']=$errors; d['warning_count']=$warnings; print(json.dumps(d, indent=2))"
      rm "$JSON_FILE"
    else
      echo -e "\n================================================="
      if [[ $errors -eq 0 && $warnings -eq 0 ]]; then
        echo -e "${GREEN}Doctor found no issues. System is healthy.${NC}"
      elif [[ $errors -eq 0 ]]; then
        echo -e "${YELLOW}Doctor completed with 0 errors and $warnings warnings.${NC}"
      else
        echo -e "${RED}Doctor found $errors errors and $warnings warnings. Please fix the errors to ensure stable operation.${NC}"
        exit 1
      fi
    fi
    ;;
  *)
    usage
    exit 1
    ;;
esac
