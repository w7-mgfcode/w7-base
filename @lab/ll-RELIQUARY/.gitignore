# Runtime secrets — never commit (use .env.sops when ready)
.env

# Container volumes
data/

# Dogfood / playwright artifacts (keep .gitkeep + manually-curated reports)
dogfood-output/*/
!dogfood-output/.gitkeep
!dogfood-output/*/report.md

# Stitch generated screen exports (only DESIGN.md is committed)
.stitch/screens/
.stitch/projects/
.stitch/*.tmp

# Node / Python
node_modules/
__pycache__/
*.pyc
.pytest_cache/
.venv/

# Vite / build outputs
apps/ui/dist/
apps/ui/.vite/

# Editor noise
.DS_Store
*.swp
