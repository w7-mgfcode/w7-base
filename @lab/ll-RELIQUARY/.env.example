# ─────────────────────────────────────────────────────────────
#  ll-RELIQUARY — environment schema (committed, placeholders only)
#  Copy to .env, fill values, NEVER commit .env. Use .env.sops for
#  encrypted secrets once they exist.
# ─────────────────────────────────────────────────────────────

# ── Service ports (host-side) ────────────────────────────────
UI_PORT=4242
API_PORT=8282
DB_PORT=5454
CACHE_PORT=6464

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info

# ── Postgres (game state: users, cards, decks, collections) ──
POSTGRES_USER=reliquary
POSTGRES_PASSWORD=change-me-in-real-env
POSTGRES_DB=reliquary

# ── Redis (sessions, leaderboards, real-time draws) ──────────
REDIS_PASSWORD=change-me-in-real-env

# ── API ──────────────────────────────────────────────────────
API_SESSION_SECRET=change-me-32-bytes-hex
# Comma-separated CORS origins for the UI dev / prod hosts
API_CORS_ORIGINS=http://localhost:4242

# ── UI build-time ────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8282
VITE_GAME_TITLE=Reliquary
