# W7-Base Global GitIgnore

# Always ignore secrets
.env
*.env
!.env.example
!.env.sops

# Ignore persistent data volumes
data/
*/data/
*/*/data/

# Ignore local config
.omg/state/
.specstory/
*.tar.gz
.age_key.txt
.bin/age*
.bin/sops

# Agent artifacts & Testing outputs
.agents/
.claude/
.memo/
.planning/
.w7-meta
dogfood-output/
PRPs/
**/node_modules/
**/.omg/

# Integration & Development scripts
*.sh
*.py
w7.integrated
w7.tmp
w7_new
w7_top.sh
w7.bak
