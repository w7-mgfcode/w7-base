# W7 Metadata
W7_STACK_NAME=ll-knowrag
W7_ZONE=@lab

# Infrastructure - Database
DB_PORT=54322
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Infrastructure - PostgREST Security
# JWT_SECRET must be at least 32 characters long
JWT_SECRET=this_is_a_very_long_secret_key_32_chars_long_exactly_now
PGRST_DB_ANON_ROLE=postgres

# Infrastructure - External Supabase / PostgREST Gateway
SUPABASE_URL=http://knowrag-proxy
# SUPABASE_SERVICE_KEY is the JWT used by the API to talk to PostgREST/Supabase
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoicG9zdGdyZXMiLCJpc3MiOiJzdXBhYmFzZSIsImlhdCI6MTc3NDg1NTA3NywiZXhwIjoyMDkwMjE1MDc3fQ.OQJSJtLi9AnW_uyS8DOOar3CweDqyhpYccohOwBtTmw

# Infrastructure - Internal Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Port Configuration
API_PORT=8181
MCP_PORT=8051
UI_PORT=3737
API_SERVICE_URL=http://knowrag-api:8181

# Feature Flags
USE_HYBRID_SEARCH=false
USE_RERANKING=false
USE_CONTEXTUAL_EMBEDDINGS=false
ENABLE_CODE_EXAMPLES=false

# Reranking Provider Settings
RERANKING_PROVIDER=lexical
RERANKING_MODEL=
RERANKING_PROVIDER_URL=
RERANKING_API_KEY=
RERANKING_TOP_N=0

# Crawl Settings
CRAWL_MAX_CONCURRENT=4
CRAWL_BATCH_SIZE=10
CRAWL_PAGE_TIMEOUT=30
CRAWL_WAIT_STRATEGY=networkidle

# LLM / Embedding Provider Settings
HOST=0.0.0.0
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Upload Limits
MAX_UPLOAD_SIZE_MB=50

# Runtime Logging
LOG_LEVEL=info
