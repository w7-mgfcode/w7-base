# W7 Metadata
W7_STACK_NAME=ll-knowrag
W7_ZONE=@lab

# Infrastructure - Vector Database
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Infrastructure - Open WebUI
WEBUI_PORT=3000

# Infrastructure - Internal Ollama
OLLAMA_BASE_URL=http://ollama:11434

# Port Configuration
API_PORT=8181
MCP_PORT=8051
UI_PORT=3737
API_SERVICE_URL=http://knowrag-api:8181

# Feature Flags
USE_HYBRID_SEARCH=false
USE_RERANKING=false
USE_CONTEXTUAL_EMBEDDINGS=false
ENABLE_CODE_EXAMPLES=false

# Reranking Provider Settings
RERANKING_PROVIDER=lexical
RERANKING_MODEL=
RERANKING_PROVIDER_URL=
RERANKING_API_KEY=
RERANKING_TOP_N=0

# Crawl Settings
CRAWL_MAX_CONCURRENT=4
CRAWL_BATCH_SIZE=10
CRAWL_PAGE_TIMEOUT=30
CRAWL_WAIT_STRATEGY=networkidle

# Crawl4AI browser-based crawling (enables JS-rendered page support)
USE_CRAWL4AI=true
CRAWL4AI_HEADLESS=true
CRAWL4AI_VIEWPORT_WIDTH=1920
CRAWL4AI_VIEWPORT_HEIGHT=1080
CRAWL4AI_DELAY_BEFORE_RETURN=1.0
CRAWL4AI_SCAN_FULL_PAGE=true

# LLM / Embedding Provider Settings
HOST=0.0.0.0
LLM_PROVIDER=ollama
LLM_BASE_URL=http://ollama:11434
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text
CHAT_MODEL=llama3
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Upload Limits
MAX_UPLOAD_SIZE_MB=50

# Runtime Logging
LOG_LEVEL=info
